{
  "name": "snooze-web",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 4173",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,md}\"",
    "codegen": "openapi-typescript ../api/openapi.yaml -o src/lib/api/types.gen.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test --config=tests/e2e/playwright.config.ts",
    "e2e:headed": "playwright test --config=tests/e2e/playwright.config.ts --ui",
    "e2e:build": "npm run build && cd .. && go build -o web/tests/e2e/.bin/snooze-server ./cmd/snooze-server && cd web"
  },
  "dependencies": {
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@fontsource-variable/ibm-plex-sans": "5.2.8",
    "@fontsource/ibm-plex-mono": "5.2.7",
    "@radix-ui/react-checkbox": "1.1.4",
    "@radix-ui/react-dialog": "1.1.6",
    "@radix-ui/react-dropdown-menu": "2.1.6",
    "@radix-ui/react-popover": "1.1.6",
    "@radix-ui/react-radio-group": "1.2.3",
    "@radix-ui/react-select": "2.1.6",
    "@radix-ui/react-switch": "1.1.3",
    "@radix-ui/react-tabs": "1.1.3",
    "@radix-ui/react-toast": "1.2.6",
    "@radix-ui/react-tooltip": "1.2.0",
    "@tanstack/react-query": "5.62.7",
    "@tanstack/react-router": "1.95.0",
    "@tanstack/react-table": "8.20.6",
    "chart.js": "4.4.7",
    "date-fns": "4.1.0",
    "diff": "7.0.0",
    "jwt-decode": "4.0.0",
    "react": "19.0.0",
    "react-chartjs-2": "5.2.0",
    "react-day-picker": "9.14.0",
    "react-dom": "19.0.0",
    "react-hook-form": "7.54.1",
    "yaml": "2.6.1",
    "zustand": "5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "9.16.0",
    "@playwright/test": "1.49.1",
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@testing-library/user-event": "14.5.2",
    "@types/diff": "7.0.0",
    "@types/node": "22.10.1",
    "@types/react": "19.0.1",
    "@types/react-dom": "19.0.1",
    "@vitejs/plugin-react": "4.3.4",
    "axe-core": "4.10.2",
    "eslint": "9.16.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react-hooks": "5.0.0",
    "eslint-plugin-react-refresh": "0.4.16",
    "globals": "15.13.0",
    "jsdom": "25.0.1",
    "msw": "2.7.0",
    "openapi-typescript": "7.4.4",
    "prettier": "3.4.2",
    "typescript": "5.7.2",
    "typescript-eslint": "8.18.0",
    "vite": "6.0.3",
    "vitest": "2.1.8"
  }
}
