#!/bin/sh
set -e

case "$1" in
    install|upgrade)
        if ! getent group snooze >/dev/null; then
            addgroup --system snooze
        fi
        if ! getent passwd snooze >/dev/null; then
            adduser --system --ingroup snooze --home /var/lib/snooze \
                --shell /usr/sbin/nologin --gecos "Snooze service" snooze
        fi
        ;;
esac

#DEBHELPER#

exit 0
