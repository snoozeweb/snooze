#!/usr/bin/make -f
export DH_VERBOSE = 1
export GOFLAGS = -trimpath -tags=osusergo,netgo
export GOTOOLCHAIN = local

%:
	dh $@

override_dh_auto_build:
	go build -o build/ ./cmd/...

override_dh_auto_install:
	install -d debian/tmp/usr/bin
	cp build/snooze* debian/tmp/usr/bin/

override_dh_auto_test:
	# Tests are run separately via the CI pipeline (`task test`). Skip during
	# the package build so the Debian build chroot does not need to spin up
	# MongoDB / PostgreSQL / Redis fixtures.
